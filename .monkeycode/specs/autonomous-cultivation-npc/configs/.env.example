# ==========================================
# 环境变量配置模板
# ==========================================
# 复制为 .env 并填入实际值

# ===== 服务器配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_NODE_NAME=node-1
MAX_ENTITIES_PER_NODE=1000
GAME_TICK_INTERVAL_MS=1000

# ===== 数据库配置 =====
DATABASE_URL=postgresql://user:password@localhost:5432/cultivation_world
DATABASE_MAX_CONNECTIONS=100
DATABASE_IDLE_TIMEOUT=300

REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# ===== DeepSeek API 配置 =====
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_RATE_LIMIT_PER_MIN=600
DEEPSEEK_TIMEOUT_SECONDS=10

# ===== LLM 成本控制 =====
LLM_TEMPLATE_MATCH_THRESHOLD=0.5
LLM_MAX_TOKENS_PER_CALL=500
LLM_DAILY_BUDGET_USD=100
LLM_EMERGENCY_CUTOFF_PERCENT=80

# ===== 天道算法配置 =====
KARMA_DECAY_RATE_PER_HOUR=0.01
KARMA_CAP=10000
HEAVENLY_TAX_BASE_RATE=0.01
RESOURCE_SPAWN_BASE_INTERVAL_MINUTES=60

# ===== 世界初始化配置 =====
WORLD_SEED=42
WORLD_TEMPLATE=default_5_realms
INITIAL_NPC_COUNT=50
INITIAL_SECT_COUNT=3
WORLD_AGE_START_YEAR=1

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout,file
LOG_FILE_PATH=/var/log/cultivation-world/server.log

# ===== 监控配置 =====
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=30
